PAPERBASE_DATABASE_URL=postgresql+psycopg://paperbase:paperbase@postgres:5432/paperbase
PAPERBASE_ELASTICSEARCH_URL=http://elasticsearch:9200
PAPERBASE_REQUIRE_SEARCH_BACKEND=false
PAPERBASE_REDIS_URL=redis://redis:6379/0
PAPERBASE_WORKER_QUEUE_BACKEND=redis
PAPERBASE_WORKER_QUEUE_NAME=paperbase:jobs
PAPERBASE_WORKER_RETRY_LIMIT=3
PAPERBASE_WORKER_STALE_JOB_SECONDS=900
PAPERBASE_OBJECT_STORE_ENDPOINT=http://minio:9000
PAPERBASE_OBJECT_STORE_BACKEND=s3
PAPERBASE_OBJECT_STORE_BUCKET=paperbase
PAPERBASE_OBJECT_STORE_ACCESS_KEY=paperbase
PAPERBASE_OBJECT_STORE_SECRET_KEY=paperbase123
PAPERBASE_OBJECT_STORE_LOCAL_ROOT=/app/data/object-store
PAPERBASE_UPLOAD_STAGING_DIR=/app/data/uploads/paperbase-ingest
PAPERBASE_DOWNLOAD_CACHE_DIR=/app/data/cache/paperbase-downloads
PAPERBASE_DOWNLOAD_CACHE_TTL_SECONDS=86400
PAPERBASE_EMBEDDING_PROVIDER=openai
PAPERBASE_EMBEDDING_MODEL=text-embedding-3-small
PAPERBASE_API_HOST=0.0.0.0
PAPERBASE_API_PORT=8080
PAPERBASE_WORKER_POLL_INTERVAL_SECONDS=2.0
RA_LOG_LEVEL=INFO
RA_LOG_FILE=/app/data/logs/ra.log
RA_MODEL=gpt-4o-mini
