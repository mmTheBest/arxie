# Copy to .env and fill local values. Do not commit .env.

# Model API keys
OPENAI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Model configuration
RA_MODEL=gpt-4o-mini
RA_MODEL_EVAL=gpt-4o
PAPERBASE_MODEL_PROVIDER=openai
PAPERBASE_MODEL_NAME=
PAPERBASE_MODEL_CLI_TIMEOUT_SECONDS=240
PAPERBASE_MODEL_ENTAILMENT_GRADER=false
PAPERBASE_CODEX_COMMAND=codex
PAPERBASE_CLAUDE_COMMAND=claude
PAPERBASE_ALLOW_AGENTIC_CLI=false
PAPERBASE_EXPECTED_WORKER_MODEL_PROVIDER=
CLAUDE_CODE_OAUTH_TOKEN=

# Logging
RA_LOG_LEVEL=INFO
RA_LOG_FILE=logs/ra.log

# Cache
RA_CACHE_DIR=data/cache
RA_CACHE_TTL=86400

# Paperbase runtime
PAPERBASE_DATABASE_URL=postgresql+psycopg://paperbase:paperbase@localhost:5432/paperbase
PAPERBASE_ELASTICSEARCH_URL=http://localhost:9200
PAPERBASE_REQUIRE_SEARCH_BACKEND=false
PAPERBASE_REDIS_URL=redis://localhost:6379/0
PAPERBASE_WORKER_QUEUE_BACKEND=redis
PAPERBASE_WORKER_QUEUE_NAME=paperbase:jobs
PAPERBASE_WORKER_PROJECT_ID=
PAPERBASE_WORKER_ID=
PAPERBASE_WORKER_RETRY_LIMIT=3
PAPERBASE_WORKER_STALE_JOB_SECONDS=900
PAPERBASE_WORKER_HEARTBEAT_STALE_SECONDS=900
PAPERBASE_HOSTED_MODE=false
PAPERBASE_HOSTED_API_TOKEN=
PAPERBASE_HOSTED_API_KEYS=
PAPERBASE_HOSTED_RATE_LIMIT_WINDOW_SECONDS=60
PAPERBASE_HOSTED_RATE_LIMIT_MAX_REQUESTS=60
PAPERBASE_LOCAL_PATH_IMPORT_ALLOWED_ROOTS=
PAPERBASE_OBJECT_STORE_ENDPOINT=http://localhost:9000
PAPERBASE_OBJECT_STORE_BACKEND=s3
PAPERBASE_OBJECT_STORE_BUCKET=paperbase
PAPERBASE_OBJECT_STORE_ACCESS_KEY=paperbase
PAPERBASE_OBJECT_STORE_SECRET_KEY=paperbase123
PAPERBASE_OBJECT_STORE_LOCAL_ROOT=data/object-store
PAPERBASE_UPLOAD_STAGING_DIR=data/uploads/paperbase-ingest
PAPERBASE_UPLOAD_MAX_FILE_COUNT=500
PAPERBASE_UPLOAD_MAX_SINGLE_FILE_BYTES=104857600
PAPERBASE_UPLOAD_MAX_TOTAL_BYTES=2147483648
PAPERBASE_DOWNLOAD_CACHE_DIR=data/cache/paperbase-downloads
PAPERBASE_DOWNLOAD_CACHE_TTL_SECONDS=86400
PAPERBASE_EMBEDDING_PROVIDER=openai
PAPERBASE_EMBEDDING_MODEL=text-embedding-3-small
PAPERBASE_API_HOST=0.0.0.0
PAPERBASE_API_PORT=8080
PAPERBASE_WORKER_POLL_INTERVAL_SECONDS=2.0
